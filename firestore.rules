rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidVote(data) {
      return data.keys().hasAll(['teamId', 'userId', 'votedAt'])
        && data.keys().size() == 3
        && data.teamId in ['madrid', 'city', 'bayern', 'arsenal', 'barcelona']
        && data.userId == request.auth.uid
        && data.votedAt == request.time;
    }

    match /votes/{userId} {
      allow get, list: if true;
      allow create: if isOwner(userId)
        && isValidId(userId)
        && !exists(/databases/$(database)/documents/votes/$(userId))
        && isValidVote(request.resource.data);
      
      // Updates and deletes not allowed for one-time voting
      allow update, delete: if false;
    }
  }
}
